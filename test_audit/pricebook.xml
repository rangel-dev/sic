<?xml version="1.0" encoding="UTF-8"?>
<pricebooks xmlns="http://www.demandware.com/xml/impex/pricebook/2006-10-31">
    <!-- PRICEBOOK NATURA LISTA -->
    <pricebook>
        <header pricebook-id="natura-brazil-list-prices">
            <currency>BRL</currency>
        </header>
        <price-tables>
            <!-- Check #1: price (Diverge Excel 100 vs SF 120) -->
            <price-table product-id="NATBRA-1001">
                <amount quantity="1">120.00</amount>
            </price-table>
            <!-- Check #5: logic (POR > DE: 60 > 50) -->
            <price-table product-id="NATBRA-1002">
                <amount quantity="1">50.00</amount>
            </price-table>
            <!-- Check #8: missing (Falta DE) - Vamos colocar só o POR depois -->
            <price-table product-id="NATBRA-1003">
                <amount quantity="1">0.00</amount>
            </price-table>
            <!-- Check #10: offline (No Excel mas offline no SF) -->
            <price-table product-id="NATBRA-1005">
                <amount quantity="1">100.00</amount>
            </price-table>
            <!-- Check #11: ml divergence (Marca 50 vs ML 60) -->
            <price-table product-id="NATBRA-1009">
                <amount quantity="1">50.00</amount>
            </price-table>
            <!-- Check #12: margin (Em categoria proibida com desconto) -->
            <price-table product-id="NATBRA-1010">
                <amount quantity="1">100.00</amount>
            </price-table>
            <!-- Check #11: ml divergence -->
            <price-table product-id="NATBRA-1012">
                <amount quantity="1">50.00</amount>
            </price-table>
        </price-tables>
    </pricebook>

