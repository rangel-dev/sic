{
    "venvPath": ".",
    "venv": ".venv",
    "pythonPath": ".venv/bin/python",
    "include": [
        "."
    ],
    "extraPaths": [
        "."
    ],
    "typeCheckingMode": "basic",
    "pythonVersion": "3.13",
    "analysis": {
        "autoSearchPaths": true,
        "useLibraryCodeForTypes": true,
        "diagnosticMode": "workspace"
    }
}
